# LLM settings
LITELLM_MODEL=bedrock/anthropic.claude-3-haiku-20240307-v1:0
LITELLM_API_BASE=
OPENAI_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# AWS Bedrock (for Claude Haiku)
AWS_REGION_NAME=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Paths
OUTPUT_DIR=outputs
DB_PATH=data/jobpilot.db
RESUME_PATH=data/resume.json
LOG_PATH=data/jobpilot.log
LOG_LEVEL=INFO

# Scraper
SCRAPER_TIMEOUT_SECONDS=15
